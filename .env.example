# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Mini App URL (your deployed frontend URL - MUST be HTTPS for Telegram WebApp)
MINI_APP_URL=https://your-domain.com/miniapp

# Server Port
PORT=3000

# BigBasket API Configuration
BB_BASE_URL=https://www.bigbasket.com
BB_API_VERSION=v3.1.0
BB_CHANNEL=bb-android
BB_USER_AGENT=BigBasket/7.10.2 (Android; SDK 33; arm64-v8a)

# Override OTP endpoints if you capture fresh ones from mitmproxy
# Example: After capturing traffic, update these paths
# BB_SEND_OTP_PATH=/mapi/v3.1.0/login/send-otp/
# BB_VERIFY_OTP_PATH=/mapi/v3.1.0/login/verify-otp/

# Session Secret
SESSION_SECRET=your_session_secret_here
