# ============================================
# BigBasket Telegram Mini App - Configuration
# ============================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Mini App URL (MUST be HTTPS for Telegram WebApp)
# For local dev: use ngrok (ngrok http 3000)
# For production: your deployed domain
MINI_APP_URL=https://your-domain.com/miniapp

# Server Port
PORT=3000

# ============================================
# BigBasket API Configuration
# Based on captured traffic from v8.29.1
# ============================================
BB_BASE_URL=https://www.bigbasket.com
BB_API_VERSION=v4.2.0
BB_CHANNEL=bb-android
BB_USER_AGENT=Dalvik/2.1.0 (Linux; U; Android 13; SM-S911B Build/TP1A.220624.014)

# ============================================
# Override API Endpoints (if you capture fresh ones)
# These are from captured traffic - update if BigBasket changes them
# ============================================
# BB_SEND_OTP_PATH=/mapi/v4.2.0/login/otp-send/
# BB_VERIFY_OTP_PATH=/mapi/v4.2.0/login/otp-verify/

# ============================================
# Session Secret (generate a random string)
# ============================================
SESSION_SECRET=change_this_to_a_random_secret_string

# ============================================
# Optional: Pre-set your BigBasket token
# (captured from mitmproxy - use /settoken in bot instead)
# ============================================
# BB_ACCESS_TOKEN=your_captured_jwt_token
# BB_VISITOR_ID=your_visitor_id
# BB_MEMBER_ID=your_member_id
